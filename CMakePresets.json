{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 21,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "windows-base",
            "hidden": true,
            "binaryDir": "${sourceDir}/build/${presetName}",
            "cacheVariables": {
                "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/${presetName}"
            }
        },
        {
            "name": "Debug",
            "displayName": "Debug",
            "description": "Debug preset",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/conan-debug/build/generators/conan_toolchain.cmake",
                "SARIBBON_DIR": "${sourceDir}/external/SARibbonBar/install-debug",
                "CDT_DIR": "${sourceDir}/external/CDT/install-debug/cmake"
            }
        },
        {
            "name": "Release",
            "displayName": "Release",
            "description": "Release preset",
            "inherits": "windows-base",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/build/conan-release/build/generators/conan_toolchain.cmake",
                "SARIBBON_DIR": "${sourceDir}/external/SARibbonBar/install-release",
                "CDT_DIR": "${sourceDir}/external/CDT/install-release/cmake"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "Debug",
            "configurePreset": "Debug",
            "configuration": "Debug"
        },
        {
            "name": "Release",
            "configurePreset": "Release",
            "configuration": "Release"
        },
        {
            "name": "Debug-Runtime",
            "displayName": "Debug Runtime Install",
            "description": "Build and install the Debug Runtime component",
            "configurePreset": "Debug",
            "configuration": "Debug",
            "targets": [
                "install-runtime"
            ]
        },
        {
            "name": "Debug-PluginSDK",
            "displayName": "Debug Plugin SDK Install",
            "description": "Install the Debug PluginSDK component",
            "configurePreset": "Debug",
            "configuration": "Debug",
            "targets": [
                "install-plugin-sdk"
            ]
        },
        {
            "name": "Release-Runtime",
            "displayName": "Release Runtime Install",
            "description": "Build and install the Release Runtime component",
            "configurePreset": "Release",
            "configuration": "Release",
            "targets": [
                "install-runtime"
            ]
        },
        {
            "name": "Release-PluginSDK",
            "displayName": "Release Plugin SDK Install",
            "description": "Install the Release PluginSDK component",
            "configurePreset": "Release",
            "configuration": "Release",
            "targets": [
                "install-plugin-sdk"
            ]
        }
    ]
}
